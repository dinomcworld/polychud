# Core (required)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DATABASE_URL=postgresql://bot:password@db:5432/polymarket_bot
NODE_ENV=production

# PostgreSQL (used by docker-compose)
POSTGRES_DB=polymarket_bot
POSTGRES_USER=bot
POSTGRES_PASSWORD=password

# Polymarket API endpoints
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com

# Polling
POLL_BASE_INTERVAL_MS=21600000
POLL_MIN_INTERVAL_MS=3600000
POLL_MAX_INTERVAL_MS=86400000
RESOLUTION_CHECK_CRON=*/30 * * * *
METADATA_REFRESH_CRON=0 */6 * * *
MOMENTUM_THRESHOLD_LOW=0.02
MOMENTUM_THRESHOLD_HIGH=0.10
ON_DEMAND_CACHE_TTL_MS=60000
CLOSE_BET_PRICE_MAX_AGE_MS=30000

# Points economy (defaults, overridable per guild)
DEFAULT_STARTING_POINTS=1000
DEFAULT_MAX_BET=500
DEFAULT_MIN_BET=10
DEFAULT_DAILY_BONUS=100
MAX_ACTIVE_BETS_PER_USER=10
MAX_ACTIVE_BETS_PER_MARKET=3

# Logging
LOG_LEVEL=info
